<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= title %> | VulnShop Lab</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
  <nav class="navbar"><div class="nav-brand"><a href="/">🛒 VulnShop Lab</a><span class="vuln-badge" style="background:#16a34a">SECURE</span></div>
    <div class="nav-links"><a href="/products">Products</a><a href="/cart">Cart</a><a href="/orders">Orders</a><a href="/support">Support</a><a href="/fetch">URL Fetch</a>
      <% if (user.role === 'admin') { %><a href="/admin" class="admin-link">Admin</a><% } %>
      <a href="/profile">👤 <%= user.username %></a><a href="/logout" class="btn-logout">Logout</a></div></nav>
  <div class="warning-banner" style="background:#dcfce7;color:#166534;border-bottom:1px solid #86efac;">Remediated secure build for local lab retest and comparison.</div>

  <main class="container">
    <h1><%= isOwn ? 'My Profile' : profileUser.username + "'s Profile" %></h1>

    <div class="profile-card">
      <div class="profile-avatar">
        <% if (profileUser.avatar) { %>
          <img src="<%= profileUser.avatar %>" alt="Avatar" class="avatar-img">
        <% } else { %>
          <div class="avatar-placeholder">👤</div>
        <% } %>
      </div>
      <div class="profile-info">
        <p><strong>ID:</strong> <%= profileUser.id %></p>
        <p><strong>Username:</strong> <%= profileUser.username %></p>
        <p><strong>Email:</strong> <%= profileUser.email %></p>
        <p><strong>Joined:</strong> <%= new Date(profileUser.created_at).toLocaleDateString() %></p>
        <p><strong>Bio:</strong></p>
        <div class="bio-box"><%= profileUser.bio || 'No bio yet.' %></div>
      </div>
    </div>

    <% if (isOwn) { %>
      <section class="card">
        <h2>Update Bio</h2>
        <p>Profile bio input is validated and safely rendered.</p>
        <form method="POST" action="/profile/update">
          <textarea name="bio" rows="4"><%= profileUser.bio %></textarea>
          <button type="submit" class="btn-primary">Update Bio</button>
        </form>
      </section>

      <section class="card">
        <h2>Upload Avatar</h2>
        <p>Secure upload: only image types with size limits are allowed.</p>
        <form method="POST" action="/profile/avatar" enctype="multipart/form-data">
          <input type="file" name="avatar">
          <button type="submit" class="btn-primary">Upload</button>
        </form>
        <p class="muted">Uploaded files are in <code>/public/uploads/</code></p>
      </section>
    <% } %>
  </main>
</body>
</html>
