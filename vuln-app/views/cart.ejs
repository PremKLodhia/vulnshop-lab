<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | VulnShop Lab</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar"><div class="nav-brand"><a href="/">🛒 VulnShop Lab</a><span class="vuln-badge">⚠️ VULNERABLE</span></div>
    <div class="nav-links"><a href="/products">Products</a><a href="/cart">Cart</a><a href="/orders">Orders</a><a href="/profile">👤 <%= user.username %></a><a href="/logout" class="btn-logout">Logout</a></div></nav>
  <div class="warning-banner">⚠️ INTENTIONALLY VULNERABLE — LOCAL LAB USE ONLY</div>
  <main class="container">
    <h1>Shopping Cart</h1>
    <% if (items.length === 0) { %>
      <p>Your cart is empty. <a href="/products">Browse products</a></p>
    <% } else { %>
      <table class="table">
        <thead><tr><th>Product</th><th>Price</th><th>Qty</th><th>Subtotal</th><th>Action</th></tr></thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td><%= item.name %></td>
              <td>$<%= item.price.toFixed(2) %></td>
              <td><%= item.quantity %></td>
              <td>$<%= (item.price * item.quantity).toFixed(2) %></td>
              <td>
                <form method="POST" action="/cart/remove" style="display:inline">
                  <!-- VULNERABILITY: IDOR - any cartItemId accepted -->
                  <input type="hidden" name="cartItemId" value="<%= item.id %>">
                  <button type="submit" class="btn-danger">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <div class="cart-total">
        <h3>Total: $<%= total.toFixed(2) %></h3>
        <form method="POST" action="/cart/checkout">
          <button type="submit" class="btn-primary">Checkout</button>
        </form>
      </div>
    <% } %>
  </main>
</body>
</html>
