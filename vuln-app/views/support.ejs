<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= title %> | VulnShop Lab</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
  <nav class="navbar"><div class="nav-brand"><a href="/">🛒 VulnShop Lab</a><span class="vuln-badge">⚠️ VULNERABLE</span></div>
    <div class="nav-links"><a href="/products">Products</a><a href="/support">Support</a>
      <% if (user) { %><a href="/profile">👤 <%= user.username %></a><a href="/logout" class="btn-logout">Logout</a><% } else { %><a href="/login">Login</a><% } %>
    </div></nav>
  <div class="warning-banner">⚠️ INTENTIONALLY VULNERABLE — LOCAL LAB USE ONLY</div>

  <main class="container">
    <h1>Contact Support</h1>
    <% if (success) { %><div class="alert alert-success">Support ticket submitted successfully.</div><% } %>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <form method="POST" action="/support" class="card">
      <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= user ? user.username : '' %>" required></div>
      <div class="form-group"><label>Email</label><input type="email" name="email" value="<%= user ? user.email : '' %>" required></div>
      <div class="form-group"><label>Subject</label><input type="text" name="subject" required></div>
      <div class="form-group"><label>Message</label><textarea name="message" rows="5" required placeholder="Describe your issue"></textarea></div>
      <button type="submit" class="btn-primary">Submit Ticket</button>
    </form>

    <p class="muted">For demo: all tickets can be viewed at <a href="/support/tickets">/support/tickets</a> (intentionally insecure).</p>
  </main>
</body>
</html>
