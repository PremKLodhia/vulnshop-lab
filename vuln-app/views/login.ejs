<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | VulnShop Lab</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand"><a href="/">🛒 VulnShop Lab</a><span class="vuln-badge">⚠️ VULNERABLE</span></div>
    <div class="nav-links">
      <a href="/products">Products</a>
      <% if (user) { %><a href="/cart">Cart</a><a href="/orders">Orders</a><a href="/profile">👤 <%= user.username %></a><a href="/logout" class="btn-logout">Logout</a>
      <% } else { %><a href="/login">Login</a><a href="/register">Register</a><% } %>
    </div>
  </nav>
  <div class="warning-banner">⚠️ INTENTIONALLY VULNERABLE — LOCAL LAB USE ONLY</div>
  <main class="container">
    <div class="auth-box">
      <h1>Login</h1>
      <% if (error) { %>
        <!-- VULNERABILITY: Raw error message rendered unescaped (may contain HTML from SQLi error) -->
        <div class="alert alert-error"><%- error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="form-group">
          <label>Username</label>
          <!-- VULNERABILITY: SQLi hint - try: admin'-- -->
          <input type="text" name="username" placeholder="Try: admin'-- for SQLi demo" required>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="Password">
        </div>
        <button type="submit" class="btn-primary">Login</button>
      </form>
      <p>Don't have an account? <a href="/register">Register</a></p>
      <div class="demo-creds">
        <strong>Demo Accounts:</strong><br>
        alice / password123<br>
        bob / bobspassword<br>
        admin / admin1234
      </div>
    </div>
  </main>
</body>
</html>
