<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= title %> | VulnShop Lab</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
  <nav class="navbar"><div class="nav-brand"><a href="/">🛒 VulnShop Lab</a><span class="vuln-badge">⚠️ VULNERABLE</span></div>
    <div class="nav-links"><a href="/products">Products</a><a href="/cart">Cart</a><a href="/orders">Orders</a><a href="/profile">👤 <%= user.username %></a><a href="/logout" class="btn-logout">Logout</a></div></nav>
  <div class="warning-banner">⚠️ INTENTIONALLY VULNERABLE — LOCAL LAB USE ONLY</div>
  <main class="container">
    <h1>Order #<%= order.id %> Details</h1>

    <!-- VULNERABILITY: Displays order owner's email even when another user accesses this order via IDOR -->
    <div class="card">
      <p><strong>Order Owner:</strong> <%= owner.username %> (<%= owner.email %>)</p>
      <p><strong>Status:</strong> <%= order.status %></p>
      <p><strong>Total:</strong> $<%= order.total.toFixed(2) %></p>
      <p><strong>Date:</strong> <%= new Date(order.created_at).toLocaleString() %></p>
    </div>

    <h2>Items</h2>
    <table class="table">
      <thead><tr><th>Product</th><th>Price</th><th>Quantity</th></tr></thead>
      <tbody>
        <% items.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td>$<%= item.price.toFixed(2) %></td>
            <td><%= item.quantity %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>
</body>
</html>
